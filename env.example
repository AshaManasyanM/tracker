# Copy to .env locally (never commit .env). Required for cloud login + saved tournaments.
# Project URL must be origin only (no /rest/v1 path) — copy "Project URL" from Settings → API.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# One-time CLI only: create a confirmed admin Auth user (never use in the browser or in Vite).
# Dashboard → Settings → API → copy the secret key whose role is service_role (NOT anon / NOT publishable).
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: bootstrap an Auth user from the CLI (same as Register in the app):
#   npm run auth:create-user -- you@example.com yourPassword
#
# Create a confirmed admin (bypasses email confirm; needs service role in .env):
#   npm run auth:create-admin -- admin@example.com 'YourStrongPassword'
